# Local Docker Compose environment (db + api + nginx)
#
# Copy to `.env.compose` (not committed) for local development:
#   cp .env.compose.example .env.compose
#
# NOTE: This repo can also run fully serverless using Supabase Edge Functions (see README_DEPLOY.md).

# Database
POSTGRES_DB=jd_boujdour
POSTGRES_USER=app_user
POSTGRES_PASSWORD=ChangeMe123!

# API core
NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://app_user:ChangeMe123!@db:5432/jd_boujdour
JWT_SECRET=change-me-please-very-long

# Admin (required to use /admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123456!
ADMIN_SYNC_PASSWORD_ON_START=false

# Tokens lifetime
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_DAYS=7

# Admin security
ADMIN_LOCKOUT_MAX_ATTEMPTS=5
ADMIN_LOCKOUT_MINUTES=15

# Rate limits
LEADS_RATE_LIMIT_WINDOW_MS=60000
LEADS_RATE_LIMIT_MAX=5
ADMIN_RATE_LIMIT_WINDOW_MS=60000
ADMIN_RATE_LIMIT_MAX=30

# CORS (comma-separated). Use "*" only if you don't need credentials.
CORS_ORIGIN=http://localhost:8080

# Turnstile (captcha)
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
