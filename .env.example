# Backend environment configuration example

# Core secrets
JWT_SECRET=change-me-to-strong-long-secret
DATABASE_URL=postgresql://user:password@localhost:5432/jd_boujdour

# Admin credentials (use strong password in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
ADMIN_SYNC_PASSWORD_ON_START=true

# Tokens lifetime
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_DAYS=7

# Admin security
ADMIN_LOCKOUT_MAX_ATTEMPTS=5
ADMIN_LOCKOUT_MINUTES=15

# Leads rate limits
LEADS_RATE_LIMIT_WINDOW_MS=60000
LEADS_RATE_LIMIT_MAX=5

# Turnstile captcha
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Server
PORT=3000

# Logging
NODE_ENV=development
