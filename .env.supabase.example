# Supabase control (do not commit your real .env.supabase)
# 1) Copy to `.env.supabase`
# 2) Fill values from Supabase dashboard / personal settings

# Personal access token (Supabase Dashboard -> Account -> Access Tokens)
SUPABASE_ACCESS_TOKEN=

# Project ref (the short id in your project URL, e.g. https://supabase.com/dashboard/project/<ref>)
SUPABASE_PROJECT_REF=

# Optional: DB password (used by `supabase link` to avoid prompts)
SUPABASE_DB_PASSWORD=

# Optional (Edge Functions): used as secrets in Supabase (NOT for local file)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# ADMIN_JWT_SECRET=
# TURNSTILE_ENABLED=false
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# CORS_ORIGIN=*
#
# Admin auth (Edge Functions)
# JWT_SECRET=
# ACCESS_TOKEN_TTL_SECONDS=900
# REFRESH_TOKEN_DAYS=7
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=ChangeMe123456!
# ADMIN_SYNC_PASSWORD_ON_START=false
# ADMIN_LOCKOUT_MAX_ATTEMPTS=5
# ADMIN_LOCKOUT_MINUTES=15
